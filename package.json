{
  "name": "photopainter-converter",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop converter for Waveshare PhotoPainter images",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "vite": "vite build && vite preview",
    "vite:ugly": "vite build --watch || vite preview",
    "dist:ci": "vite build && electron-builder --publish never",
    "build:mac": "vite build && electron-builder --mac dir --publish never",
    "build:win": "vite build && electron-builder --win portable --publish never && node -e \"const fs=require('node:fs');const path=require('node:path');const release=path.join(process.cwd(),'release');if(fs.existsSync(release)){for(const name of fs.readdirSync(release)){if(/^win(?:-[^-]+)?-unpacked$/.test(name)||name==='builder-debug.yml'||name==='builder-effective-config.yaml'){fs.rmSync(path.join(release,name),{recursive:true,force:true});}}}\""
  },
  "dependencies": {
    "heic-to": "^1.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-easy-crop": "^5.5.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.matko.photopainterconverter",
    "productName": "PhotoPainter Converter",
    "asar": true,
    "beforeBuild": "scripts/generate-icons.cjs",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "category": "public.app-category.graphics-design",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.ico"
    }
  }
}
