{
  "name": "photopainter-converter",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop converter for Waveshare PhotoPainter images",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:renderer": "vite build",
    "build": "npm run typecheck && npm run build:renderer",
    "preview": "vite preview",
    "start": "npm run build:renderer && electron .",
    "dist": "npm run build && electron-builder",
    "dist:ci": "npm run build && electron-builder --publish never"
  },
  "dependencies": {
    "heic-to": "^1.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-easy-crop": "^5.5.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.matko.photopainterconverter",
    "productName": "PhotoPainter Converter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Graphics"
    }
  }
}