{
  "name": "photopainter-converter",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop converter for Waveshare PhotoPainter images",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "vite": "vite build && vite preview",
    "vite:ugly": "vite build --watch || vite preview",
    "dist:ci": "vite build && electron-builder --publish never",
    "build:mac": "vite build && electron-builder --mac dmg --publish never",
    "build:win": "vite build && electron-builder --win nsis --publish never",
    "build:deb": "vite build && electron-builder --linux deb --publish never"
  },
  "dependencies": {
    "heic-to": "^1.3.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-easy-crop": "^5.5.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.matko.photopainterconverter",
    "productName": "PhotoPainter Converter",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics"
    }
  }
}